PUBLIC_DOMAIN=meet.freiza.cloud
PUBLIC_URL=https://meet.freiza.cloud
JVB_ADVERTISE_IPS=72.61.233.6
TZ=Asia/Kolkata
JITSI_IMAGE_VERSION=stable-10888

# Generate unique values before deploying:
# ./scripts/generate-passwords.sh
JICOFO_AUTH_PASSWORD=replace-with-generated-value
JVB_AUTH_PASSWORD=replace-with-generated-value
JIBRI_RECORDER_PASSWORD=replace-with-generated-value
JIBRI_XMPP_PASSWORD=replace-with-generated-value

# Admin/moderator rooms are handled by internal auth.
ENABLE_AUTH=1
ENABLE_GUESTS=1
AUTH_TYPE=internal

# Recording
ENABLE_RECORDING=1
ENABLE_SERVICE_RECORDING=1
JIBRI_RECORDING_RESOLUTION=1280x720
JIBRI_RECORDING_DIR=/config/recordings

# Coolify/Traefik terminates HTTPS.
DISABLE_HTTPS=1
ENABLE_LETSENCRYPT=0
ENABLE_HTTP_REDIRECT=0

# WebRTC media port exposed directly on the VPS.
JVB_PORT=10000
